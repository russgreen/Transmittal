<Window x:Class="Transmittal.Browser.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
         mc:Ignorable="d"
         Title="{Binding WindowTitle}" Height="900" Width="1400" MinWidth="900" MinHeight="600">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" x:Name="ExpanderColumn" />
            <ColumnDefinition Width="5" x:Name="SplitterColumn"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Expander Grid.Column="0" 
                  IsExpanded="{Binding IsFilePanelExpanded}"
                  ExpandDirection="Right"
                  Expanded="Expander_Expanded"
                  Collapsed="Expander_Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="10,10,10,0">
                    <TextBlock Text="Drag selected files onto the browser upload area. Double-click to open files in the default application."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,0,0,6" />
                    <TextBlock Text="{Binding RedropHint}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#FF555555"
                       Visibility="{Binding ShowRedropHint, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <Button Grid.Row="1" 
                        x:Name="SelectionButton"
                        Margin="10"
                        Content="Select all" 
                        Click="SelectionButton_Click" />

                <ListBox Grid.Row="2"
                         Margin="10"
                         Name="TransferFilesListBox"
                         SelectionMode="Extended"
                         ItemsSource="{Binding TransferFiles}"
                         PreviewMouseLeftButtonDown="TransferFilesListBox_OnPreviewMouseLeftButtonDown"
                         PreviewMouseMove="TransferFilesListBox_OnPreviewMouseMove" 
                         MouseDoubleClick="TransferFilesListBox_MouseDoubleClick" 
                         SelectionChanged="TransferFilesListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Width="16" Height="16" Margin="0,0,6,0"
                                   VerticalAlignment="Center"
                                   Source="{Binding IconUri}"
                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding FileName}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding FilePath}"
                                   FontSize="11"
                                   Foreground="#FF555555"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FilePath}" />
                                <TextBlock Text="File not found"
                                   FontSize="11"
                                   Foreground="#FFB00020">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Exists}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Expander>



        <!-- GridSplitter for resizing -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="LightGray"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"/>

        <TabControl x:Name="MainTabControl" Grid.Column="2" >
            <TabItem Header="File Transfer">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#FFD0D0D0" BorderThickness="0,0,0,1" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                            Content="Refresh"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Click="RefreshButton_OnClick" />

                            <TextBox Grid.Column="1"
                             Name="AddressBarTextBox"
                             Text="{Binding CurrentAddress, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             KeyDown="AddressBarTextBox_OnKeyDown" />

                            <Button Grid.Column="2"
                            Content="Go"
                            Padding="10,4"
                            Margin="8,0,0,0"
                            Click="GoButton_OnClick" />
                        </Grid>
                    </Border>

                    <wv2:WebView2 Grid.Row="1" Name="WebView" />
                </Grid>
            </TabItem>

            <TabItem Header="PDF Preview">
                <Border >
                    <wv2:WebView2 Name="FilePreviewWebView" />
                </Border>

            </TabItem>

        </TabControl>


    </Grid>
</Window>
