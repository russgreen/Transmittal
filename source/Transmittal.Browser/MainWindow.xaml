<Window x:Class="Transmittal.Browser.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
         mc:Ignorable="d"
         Title="{Binding WindowTitle}" Height="900" Width="1400" MinWidth="900" MinHeight="600">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#FFD0D0D0"
                BorderThickness="0,0,1,0"
                Background="#FFF8F8F8">
            <Expander IsExpanded="{Binding IsFilePanelExpanded}"
                      ExpandDirection="Right">
                <Grid Width="320">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="10,10,10,0">
                        <TextBlock Text="Drag selected files onto the browser upload area. Double-click to open files in the default application."
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding RedropHint}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="#FF555555"
                                   Visibility="{Binding ShowRedropHint, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             Margin="10"
                             Name="TransferFilesListBox"
                             SelectionMode="Extended"
                             ItemsSource="{Binding TransferFiles}"
                             PreviewMouseLeftButtonDown="TransferFilesListBox_OnPreviewMouseLeftButtonDown"
                             PreviewMouseMove="TransferFilesListBox_OnPreviewMouseMove" MouseDoubleClick="TransferFilesListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding FileName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FilePath}"
                                               FontSize="11"
                                               Foreground="#FF555555"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}" />
                                    <TextBlock Text="File not found"
                                               FontSize="11"
                                               Foreground="#FFB00020">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Exists}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Expander>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border BorderBrush="#FFD0D0D0" BorderThickness="0,0,0,1" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Refresh"
                            Padding="10,4"
                            Margin="0,0,8,0"
                            Click="RefreshButton_OnClick" />

                    <TextBox Grid.Column="1"
                             Name="AddressBarTextBox"
                             Text="{Binding CurrentAddress, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             KeyDown="AddressBarTextBox_OnKeyDown" />

                    <Button Grid.Column="2"
                            Content="Go"
                            Padding="10,4"
                            Margin="8,0,0,0"
                            Click="GoButton_OnClick" />
                </Grid>
            </Border>

            <wv2:WebView2 Grid.Row="1" Name="WebView" />
        </Grid>
    </Grid>
</Window>
